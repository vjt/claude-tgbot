TELEGRAM_BOT_TOKEN=<bot_token_from_botfather>
TELEGRAM_BOT_USERNAME=<bot_username>
# admins: receive permission-prompt DMs, also count as allowed users
TELEGRAM_ADMIN_USER_IDS=<comma-separated_numeric_ids>
# publishers: can interact with the bot but do not receive permission DMs
TELEGRAM_PUBLISHER_USER_IDS=<comma-separated_numeric_ids>
# chat scope: only updates coming from these chats reach the agent
TELEGRAM_ALLOWED_CHAT_IDS=<comma-separated_numeric_chat_ids>
