{
  "permissions": {
    "allow": [
      "Bash",
      "Monitor",
      "Skill",
      "ToolSearch",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "Read",
      "Grep",
      "Glob",
      "TodoWrite",
      "ExitPlanMode",
      "ScheduleWakeup"
    ]
  },
  "hooks": {
